# Copy to .env at the project root and fill in your values.
# Never commit .env to git.

# ── OANDA ────────────────────────────────────────────────────────────────────
OANDA_TOKEN=your-personal-access-token-here
OANDA_ACCOUNT_ID=101-001-XXXXXXX-001
OANDA_ENV=practice          # practice | live

# ── Trader ───────────────────────────────────────────────────────────────────
INSTRUMENT=EUR_USD
STRATEGY=pulse
JOURNAL=csv                 # csv | json  (sqlite requires a special image build)
TRADER_IMAGE=ghcr.io/rustyeddy/trader:latest
TRADER_VERSION=dev          # overridden by CI to e.g. v0.1.0

# ── PostgreSQL (for future use) ──────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://trader:changeme@postgres:5432/trader?sslmode=disable

# ── Pi / NFS (only needed with deploy/docker-compose.pi.yml) ─────────────────
NFS_SERVER=nas.local
NFS_CANDLE_PATH=/data/candles
