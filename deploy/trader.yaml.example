# trader daemon configuration
# Copy to /etc/trader/trader.yaml and set token or OANDA_TOKEN env var.

# OANDA credentials — leave token empty and set OANDA_TOKEN in the
# environment (or systemd EnvironmentFile) instead of storing it here.
env: practice          # practice | live
token: ""              # OANDA API token; falls back to OANDA_TOKEN env var
account_id: ""         # auto-discovered if blank (errors if multiple accounts)

rest:
  addr: ":9999"        # TCP address for REST API

journal:
  kind: json                                # json | csv
  trades_path: /var/lib/trader/live-trades.jsonl
  equity_path: /var/lib/trader/live-equity.jsonl

data:
  dir: /data/candles   # root directory for candle data

log:
  level: info          # debug | info | warn | error
  format: text         # text | json  (json enables jq filtering)
  file: ""             # optional log file path; written in addition to stdout
                       # e.g. /var/log/trader/trader.log
